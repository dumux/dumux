[Grid]
LowerLeft = -0.5 -0.5
UpperRight = 2 1.5
Cells = 50 50
Positions0 = -.5 2
Positions1 = -.5 -.4 .4 .6 1.4 1.5
Cells0 = 20
Cells1 = 2 8 4 8 2
Grading0 = 1
Grading1 = 1 1 1 1 1

[Problem]
Name = graded # name passed to the output routines
EnableGravity = false
PrintL2Error = true
EnableInertiaTerms = true

[Component]
LiquidDensity = 1
LiquidKinematicViscosity = 0.025

[ Newton ]
MaxSteps = 10
MaxRelativeShift = 1e-5

[Vtk]
WriteFaceData = false

[Flux]
UpwindWeight = 0.5
