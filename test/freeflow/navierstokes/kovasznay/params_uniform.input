[Grid]
LowerLeft = -0.5 -0.5
UpperRight = 2 1.5
Cells = 50 50
Positions0 = -.5 2
Positions1 = -.5 1.5
Cells0 = 20
Cells1 = 20
Grading0 = 1
Grading1 = 1

[Problem]
Name = uniform # name passed to the output routines
EnableGravity = false
PrintL2Error = true
EnableInertiaTerms = true

[Component]
LiquidDensity = 1
LiquidKinematicViscosity = 0.025

[ Newton ]
MaxSteps = 10
MaxRelativeShift = 1e-5

[Vtk]
WriteFaceData = false

[Flux]
UpwindWeight = 0.5
