[Grid]
# One quarter of the square 0.05x0.05 tube cross-section, using the two mirror
# symmetry planes through the tube centerlines (y=0, z=0 here correspond to the
# physical centerlines; y=0.025, z=0.025 are the true, physical tube walls).
# Same mesh spacing as the full-cross-section grid (0.0125), 1/4 the elements.
LowerLeft = 0.0 0.0 0.0
UpperRight = 0.30 0.025 0.025
Cells = 24 2 2
Refinement = 0

[Adaptive]
MinLevel = 0
MaxLevel = 6
# The initial AMR loop (main.cc) runs until nothing more is marked, bounded only
# by MaxLevel/MinElementSize -- there is no separate InitMaxLevel pass count.
# Must stay below InterfaceThickness (0.005) to resolve the diffuse interface at
# all; the old value (0.01) was COARSER than the interface width itself.
# Tightened from 0.00125 to 0.0005 for headroom, though MinElementSize turns
# out not to be the binding constraint here (verified: changing it alone left
# the output mesh byte-identical) -- RefineTolerance/CoarsenTolerance are what
# actually stop the CH-gradient indicator from refining further. Tightened
# those 10x (0.03/0.003 -> 0.003/0.0003), verified to measurably refine the
# mesh (output file size +35%) at negligible extra cost (~1s/step vs ~1.1s/step
# baseline; this scenario's baseline is only ~110s total, so there is ample
# headroom).
MinElementSize = 0.0005
RefineTolerance = 0.003
CoarsenTolerance = 0.0003
EnableInTimeStep = true
AdaptEveryNSteps = 5
RefineAtDirichletBC = false
RefineAtFluxBC = false
RefineAtSource = false
RefineAtVelocityGradient = true
VelocityGradientRefineTolerance = 0.10
VelocityGradientCoarsenTolerance = 0.01

[TimeLoop]
TEnd = 0.10
DtInitial = 1e-4
MaxTimeStepSize = 2e-3
OutputInterval = 0.025

[FreeFlow]
IncompressibleContinuity = true
EnableDilatationTerm = false
DegenerateMobility = true
PhaseFieldUpwindWeight = 1.0
PhaseFieldAdvectionVelocityScale = 0.0
VaporAdvectionVelocityScale = 0.0

[Problem]
Name = test_ff_stokes_2p_stefantube_3d
EnableInertiaTerms = false
EnableGravity = false
EnableEvaporation = true
PinMomentum = false
EnableCapillaryMomentumSource = true

SurfaceTension = 1e-3
InterfaceThickness = 0.005
Mobility = 5e-6
InterfacePosition = 0.05
InitialGasLength = 0.25
# Spherical-cap meniscus (curved in y AND z, self-consistent with the wetting
# condition at all four tube walls -- see interfacePositionAt in problem.hh).
FlatInitialInterface = false
# Must stay >= 45 deg (the Concus-Finn threshold for this square corner,
# alpha=45 deg): a bounded, corner-consistent meniscus (the spherical cap
# used here) is only the true equilibrium shape when ContactAngle+alpha>=90
# deg. Below 45 deg the corner has no bounded static solution (see
# concus-finn-1969...pdf and corner-meniscus-notes.md) -- use
# params_3d_filament.input for that regime instead.
ContactAngle = 50.0
MeniscusConcavity = -1.0
KelvinFactor = 1.0

# See params.input for the Sc (evaporation number) and EvaporationRateCoeff rationale.
Density1 = 100.0
Density2 = 0.01
Viscosity1 = 1.0
Viscosity2 = 0.01
VaporDiffusivity = 5.0
VaporSatConc = 0.20
VaporFarFieldConc = 0.05
EvaporationRateCoeff = 5000.0
PhaseChangeFactor = 2.0

[Component]
LiquidDensity = 1.0
LiquidDynamicViscosity = 1.0

[Flux]
UpwindWeight = 1.0

[Assembly]
NumericDifferenceMethod = 1

[Newton]
MinSteps = 1
MaxSteps = 30
MaxRelativeShift = 1e-6
EnableResidualCriterion = true
ResidualReduction = 1e-5
UseLineSearch = true
LineSearchMinRelaxationFactor = 1e-3
RetryTimeStepReductionFactor = 0.5
MaxTimeStepDivisions = 12

[LinearSolver]
ResidualReduction = 1e-10
MaxIterations = 1000

[VTK]
AddVelocity = true
AddProcessRank = false
