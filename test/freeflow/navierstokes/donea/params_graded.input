[Grid]
UpperRight = 1 1
Cells = 40 40
Positions0 = 0 .1 .9 1
Positions1 = 0 .1 .9 1
Cells0 = 2 8 2
Cells1 = 2 8 2
Grading0 = 1 1 1
Grading1 = 1 1 1

[Problem]
Name = graded # name passed to the output routines
EnableGravity = false
PrintL2Error = true
EnableInertiaTerms = false

[Component]
LiquidDensity  = 1.0
LiquidKinematicViscosity = 1.0

[ Newton ]
MaxSteps = 10
MaxRelativeShift = 1e-5

[FreeFlow]
EnableVelocityGradientFactor = true

[Vtk]
WriteFaceData = false
