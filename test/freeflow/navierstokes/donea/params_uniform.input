[Grid]
UpperRight = 1 1
Cells = 40 40
Positions0 = 0 1
Positions1 = 0  1
Cells0 = 10
Cells1 = 10
Grading0 = 1
Grading1 = 1

[Problem]
Name = uniform # name passed to the output routines
EnableGravity = false
PrintL2Error = true
EnableInertiaTerms = false

[Component]
LiquidDensity  = 1.0
LiquidKinematicViscosity = 1.0

[FreeFlow]
EnableVelocityGradientFactor = true

[ Newton ]
MaxSteps = 10
MaxRelativeShift = 1e-5

[Vtk]
WriteFaceData = false
