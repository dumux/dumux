[Grid]
File = annulus3d.msh

[Problem]
Name = test_hyperelastic_growth_box

[SpatialParams]
YoungsModulusCore = 1000
YoungsModulusShell = 100000
PoissonRatio = 0.40
TransitionRadius = 0.95

[Vtk]
Precision = Float64
CoordPrecision = Float64

[Newton]
EnableDynamicOutput = false
MaxRelativeShift = 1e-6

[Assembly.NumericDifference]
BaseEpsilon = 1e-8
PriVarMagnitude = 1e-3 1e-3 1e-3
