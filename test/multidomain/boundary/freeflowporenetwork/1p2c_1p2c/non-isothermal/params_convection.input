[TimeLoop]
TEnd = 10
DtInitial = 1e-2
MaxTimeStepSize = 1

[PNM.Grid]
NumPores = 2
LowerLeft = 2.5e-3 0
UpperRight = 2.5e-3 2e-3
PoreInscribedRadius = 1e-4
PoreGeometry = Cube
ThroatCrossSectionShape = Square
BoundaryPoreLabels = xMin:0 xMax:1 yMin:2 yMax:3
PriorityList = 2 3 0 1

[FreeFlow.Grid]
LowerLeft = 0 2e-3
UpperRight = 5e-3 4e-3
UpstreamCells0 = 5
CellsPerThroat = 3
DownstreamCells0 = 5
Cells1 = 6

[Problem]
EnableGravity = false
VerticalFlow = true

[FreeFlow.Problem]
Name = ff
PressureDifference = 1e3 # [Pa]
InitialPressure = 1e5 # [Pa]
InitialMoleFraction = 1e-3
TemperatureDifference = 0 # [K]
InitialTemperature = 298.15 # [K]
EnableInertiaTerms = false

[PNM.Problem]
Name = pnm
InitialTemperature = 328.15 # [K]
PressureBottom = 1.02e5
MoleFractionBottom = 2e-3

[Vtk]
OutputName = test_convection
AddVelocity = true

[Component] #water
LiquidDensity = 1e3
LiquidKinematicViscosity = 1e-6
LiquidHeatCapacity = 4184.0 # [J/(kg K)]
LiquidThermalConductivity = 0.68

[Component] #solid (for compatability)
SolidDensity = 2700
SolidThermalConductivity = 2.8
SolidHeatCapacity = 790

[Assembly]
NumericDifference.BaseEpsilon = 1e-4
