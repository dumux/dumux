[TimeLoop]
TEnd = 10
DtInitial = 1e-5
MaxTimeStepSize = 1

[PNM.Grid]
NumPores = 2
LowerLeft = 0.5e-3 -1e-3
UpperRight = 0.5e-3 0.0
PoreInscribedRadius = 1e-4
PoreGeometry = Sphere
ThroatCrossSectionShape = Circle
BoundaryPoreLabels = xMin:0 xMax:1 yMin:2 yMax:3
PriorityList = 2 3 0 1

[FreeFlow.Grid]
LowerLeft = 0 0
UpperRight = 1e-3 1e-3
UpstreamCells0 = 5
CellsPerThroat = 5
DownstreamCells0 = 5
Cells1 = 10

[Problem]
EnableGravity = false
Advection = false #only diffusion test

[FreeFlow.Problem]
Name = ff
PressureDifference = 1000
InitialPressure = 1e5
InitialMoleFraction = 1e-3
EnableInertiaTerms = false

[PNM.Problem]
Name = pnm
PressureBottom = 1.02e5
MoleFractionBottom = 2e-3

[Vtk]
OutputName = test_diffusion
AddVelocity = true

[Assembly]
NumericDifference.BaseEpsilon = 1e-4
