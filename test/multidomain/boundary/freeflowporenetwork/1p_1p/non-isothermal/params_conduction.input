[TimeLoop]
TEnd = 10
DtInitial = 1e-5
MaxTimeStepSize = 1#1

#[PNM.Grid]
#LowerLeft = 0 0
#UpperRight = 1e-2 1e-2
#NumPores = 3 3
#PoreInscribedRadius = 5e-4
#ThroatInscribedRadius = 5e-4
#SubstractRadiiFromThroatLength = true
#DeletionProbability = 0 0 1 1
#RemoveThroatsOnBoundary = 3
#PoreGeometry = Cube
#ThroatCrossSectionShape = Square
#BoundaryPoreLabels = xMin:0 xMax:1 yMin:2 yMax:3
#PriorityList = 2 3 0 1


[PNM.Grid]
NumPores = 2
LowerLeft = 5e-3 0
UpperRight = 5e-3 1e-2
PoreInscribedRadius = 1e-4
PoreGeometry = Cube
ThroatCrossSectionShape = Square

[FreeFlow.Grid]
LowerLeft = 0 1e-2
UpperRight = 1e-2 1.2e-2
UpstreamCells0 = 5
CellsPerThroat = 3
DownstreamCells0 = 5
Cells1 = 6

[Problem]
Name = test
EnableGravity = false
VerticalFlow = false

[FreeFlow.Problem]
Name = ff
PressureDifference = 0 # [Pa]
OutletPressure = 1e5 # [Pa]
TemperatureDifference = 0 # [K]
OutletTemperature = 298.15 # [K]
EnableInertiaTerms = false
Height = 10e-4

[PNM.Problem]
Name = pnm
InitialTemperature = 328.15 # [K]
InitialPressure = 1e5 # [Pa]

[Vtk]
OutputName = test_conduction
AddVelocity = true

[Component] #water
LiquidDensity = 1e3
LiquidKinematicViscosity = 1e-6
LiquidHeatCapacity = 4184.0 # [J/(kg K)]
LiquidThermalConductivity = 0.68

[Component] #solid (for compatability)
SolidDensity = 2700
SolidThermalConductivity = 2.8
SolidHeatCapacity = 790

[Assembly]
NumericDifference.BaseEpsilon = 1e-4

[FluxOverAxisAlignedSurface]
Verbose = false

[SpatialParams]
Temperature = 298.0
