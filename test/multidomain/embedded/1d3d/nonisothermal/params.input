[TimeLoop]
DtInitial = 43200     # [s]
TEnd = 432000         # [s] = 5 years
EpisodeLength = 7200 #43200 # [s] = 0.5 years

[Voids.Grid]
File = ./grids/pipe.dgf

[Soil.Grid]
Positions0 = 0 30
Positions1 = -5 0 5
Positions2 = -5 0 5
Cells0 = 25
Cells1 = 50 50
Cells2 = 50 50
Grading1 = -1.2 1.2
Grading2 = -1.2 1.2

[Voids.Problem]
Name = 1d
InjectionRate = 0.0002 # [m³/s]
InjectionTemperature = 293.15 # [K] = 20° C

[Soil.Problem]
Name = 3d

[Problem]
EnableGravity = false

[SpatialParams]
Permeability = 1e-20

[Vtk]
OutputName = test_wellbore_heat_transport
AddVelocity = true
AddProcessRank = false

[MixedDimension]
NumCircleSegments = 200
PipeWallThermalConductivity = 0.962 # [W/(m·K)], combined conductivity of pipe wall and grout

[Component]
SolidDensity = 1800
SolidThermalConductivity = 2.78018
SolidHeatCapacity = 1778

[PointSource]
EnableBoxLumping = false

[Flux]
UpwindWeight = 0.5
