[MixedDimension]
NumCircleSegments = 256
IntegrationOrder = 2
KernelWidthFactor = 1.0
WriteIntegrationPointsToFile = false
KernelIntegrationCRL = 0.01

# A straight vertical network, offset from the bulk cell faces (x=y=0.05) to avoid
# degenerate intersections. The bulk grid is split along z (see main.cc) so the network
# is genuinely distributed across ranks.
[Vessel.Grid]
LowerLeft = 0.05 0.05 0
UpperRight = 0.05 0.05 1
Cells = 20

[Tissue.Grid]
LowerLeft = -1 -1 0
UpperRight = 1 1 1
Cells = 20 20 20
Overlap = 1

[Vessel.Problem]
Name = 1d

[Tissue.Problem]
Name = 3d

[Problem]
NormIntegrationOrder = 1
EnableGravity = false
OutputFilename = log.txt

[Vtk]
OutputName = test_md_embedded1d3d_1p1p_parallel
EnableVtkOutput = false

[Component]
LiquidKinematicViscosity = 1 # [m^2/s]
LiquidDensity = 1 # [kg/m^3]

[SpatialParams]
PermeabilityTissue = 1 # [m^2]
Radius = 0.3 # [m]

[BoundaryConditions1D]
PressureInput = 2.0
DeltaPressure = 1.0

[LinearSolver]
ResidualReduction = 1e-25

[Assembly.NumericDifference]
PriVarMagnitude = 1e5
BaseEpsilon = 1e5
