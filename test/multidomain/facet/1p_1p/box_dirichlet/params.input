[Problem]
EnableGravity = false
FractureAperture = 1e-3

[Grid]
File = ./grids/diagonal.msh

[Bulk]
Problem.Name = bulk
SpatialParams.Permeability = 1

[LowDim]
Problem.Name = lowdim
SpatialParams.Permeability = 1e12

[Assembly]
NumericDifference.BaseEpsilon = 1e3

[Component]
LiquidDensity = 1.0
LiquidKinematicViscosity = 1.0

[Vtk]
OutputName = test_md_facet_1p1p_box_dirichlet
