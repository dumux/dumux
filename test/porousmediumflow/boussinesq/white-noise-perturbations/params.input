[Problem]
# Name is expected to be overridden per test invocation via
# -Problem.Name (both main_vorticity and main_pressure read this same file).
Name = boussinesq_white_noise
# EnableGravity: read by the pressure formulation's BoussinesqCVFEDarcyLaw to
# gate the buoyancy term (must be true there); the vorticity formulation's
# gravity vector is hardcoded in BoussinesqSpatialParams and ignores this flag.
EnableGravity = true
# PRef/PenaltyFactor: pressure formulation only (weak Robin pressure reference
# at the top wall), ignored by the vorticity formulation.
PRef = 0.0
PenaltyFactor = 1e6
# PerturbAmplitude=0 (default) reproduces the unperturbed erfc baseline used by
# the dissolution-flux comparison test. Override on the command line for the
# Riaz et al. (2006) finger-count/tip-scaling experiments, e.g.:
#   -DimensionlessNumbers.Ra 4000 -Problem.PerturbAmplitude 1e-3 -TimeLoop.TStart 0.2 -TimeLoop.TEnd 10
PerturbAmplitude = 0.0
PerturbSeed = 1
# Threshold defining the finger tip (C >= TipThreshold); not reported by the
# paper, chosen and documented here.
TipThreshold = 0.01

[DimensionlessNumbers]
Ra = 8000

[Grid]
# dimensionless domain: width x height = 1 x 1
# ALUGrid simplex, parallel h-adaptive, shared by both 2D formulations (box/CVFE
# discretization doesn't care about element type; the 3D vorticity target is the only
# survivor still on YaspGrid, via the separate params3d.input): uniform base mesh,
# boundary-layer resolution comes from adaptive refinement ([Adaptive] below) instead
# of static grading. 100x100 base + MaxLevel 2 gives effective 400x400 resolution at
# the front. Cells[0] doubles as the x-column binning resolution of the finger
# diagnostics in both mains (see hasParam("Grid.Cells0") fallback there).
LowerLeft  = 0 0
UpperRight = 1 1
Cells      = 100 100
CellType   = Simplex

[Adaptive]
# both 2D formulations
MinLevel = 0
MaxLevel = 4
# Absolute-gradient refine/coarsen criterion (BoussinesqGradientMagnitudeIndicator, see
# common/adaptive/gridadaptindicator.hh): refine where the true |grad C| at an element's
# center exceeds RefineGradientThreshold, coarsen where it falls below
# CoarsenGradientThreshold -- physical thresholds, not fractions of the field's current
# range (unlike the max-neighbor-jump indicator's relative RefineTolerance/CoarsenTolerance --
# a different indicator class entirely). Both default to Ra-scaled values (1/(5*Ra) and
# 1/Ra) if left unset, so overriding [DimensionlessNumbers] Ra alone still gives a sane
# mesh; only uncomment below to override the thresholds themselves directly.
# RefineGradientThreshold = ...
# CoarsenGradientThreshold = ...
# opt-in; the _rebalance test variant switches it on
EnableDynamicLoadBalancing = false
RebalanceEvery = 5
ImbalanceTolerance = 0.15
# Partition into vertical strips (one x-interval per rank, full column top to bottom)
# instead of ALUGrid's default space-filling-curve patches -- fingers grow vertically,
# so each rank keeps its fingers for their whole descent and gets an equal share of the
# refined top boundary layer. Applies to the initial partition and (weighted) to every
# rebalance. See common/adaptive/loadbalancer.hh, VerticalStripDestinations.
VerticalStripPartitioning = false

[TimeLoop]
TEnd = 20
DtInitial = 1e-3
MaxTimeStepSize = 0.05

[Output]
VtkOutputInterval = 0.5

[Newton]
MaxSteps = 20
MaxRelativeShift = 1e-5

[LinearSolver]
# Both 2D formulations (parallel ILU+GMRES); ignored by the 3D test's direct solver.
# With the dune defaults (restart 10, ILU(0)) GMRES stops converging right after the
# first parallel adapt cycle -- parallel ILU acts blockwise per rank and needs the
# higher fill-in plus a longer restart cycle.
GMResRestart = 30
MaxIterations = 1000

[LinearSolver.Preconditioner]
ILUOrder = 1
# For test_boussinesq_white_noise_pressure_box_amg only, ignored by ILU: the default
# SymmetricCriterion builds a singular AMG hierarchy on this nonsymmetric operator
# (defect=NaN on the first application) -- see cosine-perturbations/params.input for
# where this was first found. UnSymmetricCriterion is mandatory here too.
AmgCriterionSymmetric = false

[Vtk]
AddVelocity = true