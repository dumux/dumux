[Problem]
Name = boussinesq_pressure
EnableGravity = true
PRef = 0.0
PenaltyFactor = 1e6

[DimensionlessNumbers]
Ra = 8000

[Grid]
# Graded tensor-product grid: uniform in x, refined toward the top wall (y=1)
# in y, where the C=1 Dirichlet BC drives a thin diffusive boundary layer.
# Total cell count (200 x 200) matches the old uniform grid.
Positions0 = 0 1
Cells0     = 200
Grading0   = 1.0

Positions1 = 0 0.9 1.0
Cells1     = 160 40
Grading1   = 1.0 -1.06

[TimeLoop]
TEnd = 10
DtInitial = 1e-3
MaxTimeStepSize = 0.05

[Output]
VtkOutputInterval = 0.5

[Newton]
MaxSteps = 20
MaxRelativeShift = 1e-5

[Vtk]
AddVelocity = true
